# Resend API Configuration
# Get your API key from: https://resend.com/api-keys
# Replace 'your_resend_api_key_here' with your actual API key from resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=Marpro <noreply@tzb-marpro.cz>
RESEND_ADMIN_FROM_EMAIL=Marpro Orders <orders@tzb-marpro.cz>

# Admin email for notifications
ADMIN_EMAIL=sergeevnakseniia9@gmail.com

# Google Calendar Configuration
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=your-private-key
GOOGLE_CALENDAR_ID_CONTAINERS=your-container-calendar-id
GOOGLE_CALENDAR_ID_EXCAVATORS=your-excavator-calendar-id
GOOGLE_CALENDAR_ID_CONSTRUCTIONS=your-construction-calendar-id
GOOGLE_TIME_ZONE=Europe/Prague

# Google Analytics / Google Ads Tag
# Get your tracking ID from Google Analytics or Google Ads
NEXT_PUBLIC_GA_ID=G-7ZSNC2QFYH

# Cloudinary Configuration for Reference Images
# Cloud name is safe to expose publicly, API key is public, API secret must stay server-side only.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_REFERENCE_FOLDER=references

# Cloudinary delivery settings for the References section watermark
# Upload your logo to Cloudinary first, then use its public ID here, for example: marpro/logo-watermark
NEXT_PUBLIC_CLOUDINARY_WATERMARK_PUBLIC_ID=your_logo_public_id
NEXT_PUBLIC_CLOUDINARY_WATERMARK_GRAVITY=south_east
NEXT_PUBLIC_CLOUDINARY_WATERMARK_OFFSET_X=24
NEXT_PUBLIC_CLOUDINARY_WATERMARK_OFFSET_Y=24
NEXT_PUBLIC_CLOUDINARY_WATERMARK_OPACITY=45
NEXT_PUBLIC_CLOUDINARY_WATERMARK_WIDTH_RATIO=0.18
